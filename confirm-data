def normalize_space(value):
    return re.sub(r"\s+", " ", value or "").strip()


def slug(value):
    return re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-") or "source"


def strip_tags(value):
    value = re.sub(r"(?is)<script.*?</script>|<style.*?</style>", " ", value)
    value = re.sub(r"(?s)<[^>]+>", " ", value)
    return normalize_space(html.unescape(value))


def read_csv_with_header(path):
    with path.open(newline="") as handle:
        reader = csv.reader(handle)
        header = next(reader)
        rows = [dict(zip(header, row)) for row in reader]
    return header, rows


def read_dicts(path):
    with path.open(newline="") as handle:
        return list(csv.DictReader(handle))


def add_issue(issues, severity, check, row="", field="", message="", expected="", observed="", source=""):
    issues.append(
        {
            "severity": severity,
            "check": check,
            "row": row,
            "field": field,
            "message": message,
            "expected": expected,
            "observed": observed,
            "source": source,
        }
    )


def split_sources(value):
    return [part.strip() for part in (value or "").split(";") if part.strip()]


def parse_rct_links(value):
    value = value or ""
    if value.startswith("No PubMed"):
        return []
    links = []
    for part in value.split(";"):
        part = part.strip()
        if not part:
            continue
        if "|" not in part:
            links.append({"label": "", "url": part, "pmid": ""})
            continue
        label, url = [item.strip() for item in part.split("|", 1)]
        match = re.search(r"pubmed\.ncbi\.nlm\.nih\.gov/(\d+)/?", url)
        links.append({"label": label, "url": url, "pmid": match.group(1) if match else ""})
    return links


def label_from_author_year(first_author, year):
    author = ascii_token(first_author)
    return f"{author}{year}" if author and year else ""


def ascii_token(value):
    normalized = unicodedata.normalize("NFKD", value or "")
    ascii_value = normalized.encode("ascii", "ignore").decode("ascii")
    return re.sub(r"[^A-Za-z0-9]+", "", ascii_value)


def parse_pubmed_cache():
    articles = {}
    for xml_path in sorted(EFETCH_DIR.glob("*.xml")):
        root = ET.parse(xml_path).getroot()
        for article in root.findall(".//PubmedArticle"):
            pmid = (article.findtext(".//PMID") or "").strip()
            if not pmid:
                continue
            title_el = article.find(".//ArticleTitle")
            title = normalize_space("".join(title_el.itertext())) if title_el is not None else ""
            year = ""
            for path in [
                ".//Article/Journal/JournalIssue/PubDate/Year",
                ".//Article/ArticleDate/Year",
                ".//PubmedData/History/PubMedPubDate[@PubStatus='pubmed']/Year",
            ]:
                year = (article.findtext(path) or "").strip()
                if year:
                    break
            years = sorted({(item.text or "").strip() for item in article.findall(".//Year") if (item.text or "").strip()})
            first_author = ""
            first = article.find(".//AuthorList/Author")
            if first is not None:
                first_author = (first.findtext("LastName") or first.findtext("CollectiveName") or "").strip()
            pub_types = [normalize_space("".join(item.itertext())) for item in article.findall(".//PublicationType")]
            abstract = " ".join(normalize_space("".join(item.itertext())) for item in article.findall(".//AbstractText"))
            articles[pmid] = {
                "pmid": pmid,
                "title": title,
                "year": year,
                "years": years,
                "first_author": first_author,
                "label": label_from_author_year(first_author, year),
                "pub_types": pub_types,
                "abstract": abstract,
            }
    return articles


def fetch_url(url, timeout=20):
    CACHE_DIR.mkdir(exist_ok=True)
    key = hashlib.sha256(url.encode()).hexdigest()[:24]
    cache_path = CACHE_DIR / f"{key}.txt"
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "ASM-master confirm-data/1.0 (+https://github.com/GoldenholzLab/ASM-master)"
        },
    )
    with urllib.request.urlopen(req, timeout=timeout) as response:
        content = response.read()
        content_type = response.headers.get("content-type", "")
        status = getattr(response, "status", 200)
    try:
        text = content.decode("utf-8", errors="replace")
    except Exception:
        text = ""
    if "text/html" in content_type or text.lstrip().startswith("<"):
        text = strip_tags(text)
    else:
        text = normalize_space(text)
    cache_path.write_text(text)
    return {"status": status, "content_type": content_type, "text": text[:300000], "cache": str(cache_path)}


def validate_schema(header, rows, issues):
    counts = Counter(header)
    duplicates = sorted(name for name, count in counts.items() if count > 1)
    if duplicates:
        add_issue(issues, "error", "csv_schema", field="header", message="Duplicate CSV header(s)", observed=", ".join(duplicates))
    missing = [name for name in REQUIRED_COLUMNS if name not in counts]
    if missing:
        add_issue(issues, "error", "csv_schema", field="header", message="Required column(s) missing", observed=", ".join(missing))
    if not rows:
        add_issue(issues, "error", "csv_schema", message="ASM-list.csv has no data rows")
    names = [row.get("generic_name", "") for row in rows]
    duplicate_names = sorted(name for name, count in Counter(names).items() if count > 1)
    if duplicate_names:
        add_issue(issues, "error", "csv_schema", field="generic_name", message="Duplicate generic name(s)", observed=", ".join(duplicate_names))
    filter_columns = [name for name in header if name.startswith("filter_")]
    if not filter_columns:
        add_issue(issues, "error", "csv_schema", field="header", message="No CSV-defined filter columns found")
    for row in rows:
        generic = row.get("generic_name", "")
        for column in filter_columns:
            values = [item.strip() for item in row.get(column, "").split(";") if item.strip()]
            if not values:
                add_issue(issues, "error", "csv_schema", row=generic, field=column, message="CSV-defined filter column is blank")


def validate_sources(rows, issues, source_text_by_name):
    for row in rows:
        generic = row.get("generic_name", "")
        sources = split_sources(row.get("evidence_sources", ""))
        if not sources:
            add_issue(issues, "error", "source_section", row=generic, field="evidence_sources", message="No non-RCT evidence source listed")
            continue
        for source in sources:
            if re.search(r"pubmed|clinicaltrials|trial|rct", source, re.I):
                add_issue(
                    issues,
                    "error",
                    "source_section",
                    row=generic,
                    field="evidence_sources",
                    message="RCT/PubMed source belongs in the RCT section, not evidence_sources",
                    observed=source,
                )
        for field in NON_RCT_FACT_FIELDS:
            value = normalize_space(row.get(field, ""))
            if not value:
                add_issue(issues, "error", "fact_presence", row=generic, field=field, message="Non-RCT fact field is blank")
            elif sources:
                add_issue(
                    issues,
                    "info",
                    "fact_source_coverage",
                    row=generic,
                    field=field,
                    message="Field has non-RCT source coverage listed in evidence_sources",
                    source="; ".join(sources),
                )

        if source_text_by_name:
            row_terms = [generic]
            row_terms += [part.strip() for part in row.get("alternate_generic_names", "").split(";") if part.strip()]
            row_terms += [part.strip() for part in row.get("trade_names", "").split(";") if part.strip()]
            source_hits = []
            for source in sources:
                source_text = source_text_by_name.get(source, "").lower()
                if not source_text:
                    continue
                if any(term.lower() in source_text for term in row_terms if len(term) >= 4):
                    source_hits.append(source)
            if not source_hits:
                add_issue(
                    issues,
                    "warning",
                    "online_source_review",
                    row=generic,
                    field="evidence_sources",
                    message="Fetched registered source pages did not contain the row generic/trade-name terms; manual review may be needed",
                    source="; ".join(sources),
                )


def validate_rcts(rows, issues):
    rct_rows = read_dicts(RCT_AUDIT_PATH)
    included = [row for row in rct_rows if row["status"] == "included"]
    included_by_drug = defaultdict(list)
    included_by_pmid = {}
    for row in included:
        included_by_drug[row["generic_name"]].append(row)
        included_by_pmid[row["pmid"]] = row

    pubmed = parse_pubmed_cache()
    for row in rows:
        generic = row["generic_name"]
        links = parse_rct_links(row.get("pubmed_phase_ii_iii_rct_links", ""))
        expected = sorted(item["pmid"] for item in included_by_drug.get(generic, []))
        observed = sorted(link["pmid"] for link in links)
        if expected != observed:
            add_issue(
                issues,
                "error",
                "rct_section",
                row=generic,
                field="pubmed_phase_ii_iii_rct_links",
                message="RCT PMID set in CSV does not match included PubMed RCT audit set",
                expected=", ".join(expected) or "none",
                observed=", ".join(observed) or "none",
            )
        if not expected and not row.get("pubmed_phase_ii_iii_rct_links", "").startswith("No PubMed"):
            add_issue(issues, "error", "rct_section", row=generic, field="pubmed_phase_ii_iii_rct_links", message="Expected no-RCT text")
        for link in links:
            pmid = link["pmid"]
            audit = included_by_pmid.get(pmid)
            if not pmid:
                add_issue(issues, "error", "rct_link", row=generic, field="pubmed_phase_ii_iii_rct_links", message="RCT link does not contain a PubMed PMID", observed=link["url"])
                continue
            if not audit:
                add_issue(issues, "error", "rct_link", row=generic, field="pubmed_phase_ii_iii_rct_links", message="PMID is not included in pubmed_rct_audit.csv", observed=pmid)
                continue
            expected_url = f"https://pubmed.ncbi.nlm.nih.gov/{pmid}/"
            if link["url"] != expected_url:
                add_issue(issues, "error", "rct_link", row=generic, field="pubmed_phase_ii_iii_rct_links", message="PubMed URL mismatch", expected=expected_url, observed=link["url"])
            if link["label"] != audit["label"]:
                add_issue(issues, "error", "rct_link", row=generic, field="pubmed_phase_ii_iii_rct_links", message="RCT link label mismatch with audit", expected=audit["label"], observed=link["label"])
            article = pubmed.get(pmid)
            if not article:
                add_issue(issues, "error", "pubmed_cache", row=generic, field="pubmed_phase_ii_iii_rct_links", message="PMID missing from local PubMed efetch cache", observed=pmid)
            else:
                if audit["title"] and normalize_space(audit["title"]) != article["title"]:
                    add_issue(issues, "warning", "pubmed_cache", row=generic, field="pubmed_phase_ii_iii_rct_links", message="Cached PubMed title differs from RCT audit title", expected=audit["title"], observed=article["title"])
                if audit["year"] not in article["years"]:
                    add_issue(issues, "warning", "pubmed_cache", row=generic, field="pubmed_phase_ii_iii_rct_links", message="Cached PubMed years do not include RCT audit year", expected=audit["year"], observed=", ".join(article["years"]))
                if link["label"] and not link["label"].startswith(ascii_token(audit["first_author"])):
                    add_issue(issues, "error", "rct_link", row=generic, field="pubmed_phase_ii_iii_rct_links", message="RCT label does not start with first author", expected=audit["first_author"], observed=link["label"])


def extract_percent_range(value):
    if re.match(r"^(NR|No PubMed|No qualifying|No placebo|No numeric|not comparable|Greater than placebo|Statistically)", value or "", re.I):
        return None
    leading = (value or "").split("(", 1)[0]
    numbers = []
    for match in re.finditer(r"(\d+(?:\.\d+)?)(?:\s*-\s*(\d+(?:\.\d+)?))?\s*%", leading):
        numbers.extend(float(item) for item in match.groups() if item)
    if not numbers:
        return None
    return min(numbers), max(numbers)


def format_number(value):
    value = round(float(value), 2)
    if value.is_integer():
        return str(int(value))
    return f"{value:.2f}".rstrip("0").rstrip(".")


def validate_seizure_freedom(rows, issues):
    audit_rows = read_dicts(SEIZURE_FREEDOM_AUDIT_PATH)
    expected_rows = sum(1 for row in read_dicts(RCT_AUDIT_PATH) if row["status"] == "included")
    included = defaultdict(list)
    for row in audit_rows:
        if row["included_in_csv_summary"] == "yes":
            included[row["generic_name"]].append(float(row["differential_percent"]))
    if len(audit_rows) != expected_rows:
        add_issue(issues, "error", "seizure_freedom_audit", message="Expected one seizure-freedom audit row per included RCT", expected=str(expected_rows), observed=str(len(audit_rows)))
    for row in rows:
        generic = row["generic_name"]
        value = row.get("diff_seizure_freedom_maximum_effective_dose", "")
        if included[generic]:
            low = min(included[generic])
            high = max(included[generic])
            expected = f"{format_number(low)} %" if low == high else f"{format_number(low)}-{format_number(high)} %"
            if not value.startswith(expected):
                add_issue(
                    issues,
                    "error",
                    "seizure_freedom_rollup",
                    row=generic,
                    field="diff_seizure_freedom_maximum_effective_dose",
                    message="CSV seizure-freedom differential does not match audit roll-up",
                    expected=expected,
                    observed=value,
                )
        elif extract_percent_range(value):
            add_issue(
                issues,
                "error",
                "seizure_freedom_rollup",
                row=generic,
                field="diff_seizure_freedom_maximum_effective_dose",
                message="CSV contains numeric seizure-freedom value but no included audit row supports it",
                observed=value,
            )


def validate_efficacy_outcome_audit(rows, issues):
    if not EFFICACY_OUTCOME_AUDIT_PATH.exists():
        add_issue(issues, "error", "efficacy_outcome_audit", message="Efficacy outcome audit file is missing", source=str(EFFICACY_OUTCOME_AUDIT_PATH))
        return
    audit_rows = read_dicts(EFFICACY_OUTCOME_AUDIT_PATH)
    expected_rows = sum(1 for row in read_dicts(RCT_AUDIT_PATH) if row["status"] == "included")
    if len(audit_rows) != expected_rows:
        add_issue(issues, "error", "efficacy_outcome_audit", message="Expected one efficacy audit row per included RCT", expected=str(expected_rows), observed=str(len(audit_rows)))

    configs = [
        ("rr50", "rr50_differential_percent", "rr50_included_in_csv_summary", "diff_50_responder_maximum_effective_dose"),
        ("mpc", "mpc_differential_percent", "mpc_included_in_csv_summary", "diff_median_pct_change_maximum_effective_dose"),
    ]
    included = {name: defaultdict(list) for name, *_ in configs}
    for audit in audit_rows:
        for name, diff_field, include_field, _csv_field in configs:
            if audit.get(include_field) == "yes" and audit.get(diff_field) != "":
                included[name][audit["generic_name"]].append(float(audit[diff_field]))

    for row in rows:
        generic = row["generic_name"]
        for name, _diff_field, _include_field, csv_field in configs:
            value = row.get(csv_field, "")
            values = included[name][generic]
            if values:
                low = min(values)
                high = max(values)
                expected = f"{format_number(low)} %" if low == high else f"{format_number(low)}-{format_number(high)} %"
                if not value.startswith(expected):
                    add_issue(
                        issues,
                        "error",
                        "efficacy_outcome_rollup",
                        row=generic,
                        field=csv_field,
                        message="CSV efficacy differential does not match RCT-level audit roll-up",
                        expected=expected,
                        observed=value,
                    )
            elif extract_percent_range(value):
                add_issue(
                    issues,
                    "error",
                    "efficacy_outcome_rollup",
                    row=generic,
                    field=csv_field,
                    message="CSV contains numeric efficacy value but no included efficacy audit row supports it",
                    observed=value,
                )


def validate_outcome_fields(rows, issues):
    for row in rows:
        generic = row["generic_name"]
        has_rcts = not row.get("pubmed_phase_ii_iii_rct_links", "").startswith("No PubMed")
        for field in [
            "diff_50_responder_maximum_effective_dose",
            "diff_median_pct_change_maximum_effective_dose",
            "diff_seizure_freedom_maximum_effective_dose",
        ]:
            value = row.get(field, "")
            numeric = extract_percent_range(value)
            if numeric:
                low, high = numeric
                if low < 0 or high > 100 or low > high:
                    add_issue(issues, "error", "outcome_range", row=generic, field=field, message="Outcome percentage outside 0-100% or invalid range", observed=value)
                if not has_rcts:
                    add_issue(issues, "error", "outcome_source", row=generic, field=field, message="Numeric RCT-derived outcome exists but RCT section has no PubMed RCT links", observed=value)
            elif not re.search(r"NR|No PubMed|No placebo|not extractable|not comparable|Statistically|No qualifying", value or "", re.I):
                add_issue(issues, "warning", "outcome_range", row=generic, field=field, message="Outcome field is neither numeric nor a recognized non-extractable statement", observed=value)


def validate_non_rct_fact_format(rows, issues):
    for row in rows:
        generic = row["generic_name"]
        availability = row.get("available_in_us", "")
        if not (availability.startswith("Yes") or availability.startswith("No") or "Limited" in availability):
            add_issue(issues, "warning", "fact_format", row=generic, field="available_in_us", message="Availability value is unusual", observed=row.get("available_in_us", ""))
        symptoms = row.get("adverse_symptoms_percentages", "")
        if "%" not in symptoms:
            add_issue(issues, "error", "fact_format", row=generic, field="adverse_symptoms_percentages", message="Symptom field must include percentages or an explicit 0% limited-data statement", observed=symptoms)
        if "No PubMed" not in row.get("pubmed_phase_ii_iii_rct_links", ""):
            for link in parse_rct_links(row.get("pubmed_phase_ii_iii_rct_links", "")):
                if not re.match(r"^[A-Za-z][A-Za-z0-9]+\d{4}[a-z]?$", link["label"]):
                    add_issue(issues, "error", "rct_label_format", row=generic, field="pubmed_phase_ii_iii_rct_links", message="RCT label should be FirstAuthorYear", observed=link["label"])


def validate_mechanism_fields(rows, issues):
    allowed_tiers = {"FDA label", "FDA/AES summary", "AES/FDA summary", "EMA/UK SmPC", "Peer-reviewed review", "NCBI/PubChem", "Historical/limited"}
    allowed_confidence = {"High", "Moderate", "Limited"}
    for row in rows:
        generic = row["generic_name"]
        mechanism = normalize_space(row.get("mechanism_of_action", ""))
        source = normalize_space(row.get("mechanism_source", ""))
        tier = normalize_space(row.get("mechanism_source_tier", ""))
        confidence = normalize_space(row.get("mechanism_confidence", ""))
        evidence_sources = set(split_sources(row.get("evidence_sources", "")))

        if not mechanism:
            add_issue(issues, "error", "mechanism_review", row=generic, field="mechanism_of_action", message="Mechanism is blank")
        if not source:
            add_issue(issues, "error", "mechanism_review", row=generic, field="mechanism_source", message="Mechanism source is blank")
        for item in split_sources(source):
            if item not in evidence_sources:
                add_issue(issues, "error", "mechanism_review", row=generic, field="evidence_sources", message="Mechanism source is not listed in evidence_sources", observed=item)
        if tier not in allowed_tiers:
            add_issue(issues, "error", "mechanism_review", row=generic, field="mechanism_source_tier", message="Unexpected mechanism source tier", observed=tier)
        if confidence not in allowed_confidence:
            add_issue(issues, "error", "mechanism_review", row=generic, field="mechanism_confidence", message="Unexpected mechanism confidence", observed=confidence)
        forbidden_domain = "drugs" + ".com"
        if forbidden_domain in " ".join(row.values()).lower():
            add_issue(issues, "error", "source_policy", row=generic, message="Forbidden low-trust source domain is not allowed")
        add_issue(
            issues,
            "info",
            "mechanism_review",
            row=generic,
            field="mechanism_of_action",
            message="MOA row has mechanism-specific source tier and confidence annotation",
            source=source,
        )


def validate_fda_boxed_warnings(rows, issues):
    if not FDA_BOXED_WARNING_AUDIT_PATH.exists():
        add_issue(issues, "error", "fda_boxed_warning_review", field="audit", message="FDA boxed-warning audit file is missing", source=str(FDA_BOXED_WARNING_AUDIT_PATH))
        return
    audit_rows = read_dicts(FDA_BOXED_WARNING_AUDIT_PATH)
    audit_by_name = {row.get("generic_name", ""): row for row in audit_rows}
    if len(audit_rows) != len(rows):
        add_issue(issues, "error", "fda_boxed_warning_review", field="audit", message="FDA boxed-warning audit row count mismatch", expected=str(len(rows)), observed=str(len(audit_rows)))
    for row in rows:
        generic = row["generic_name"]
        audit = audit_by_name.get(generic)
        if not audit:
            add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="fda_black_box_warning", message="Drug missing from FDA boxed-warning audit")
            continue
        for field in ["fda_black_box_warning", "fda_black_box_warning_source", "fda_black_box_warning_verified"]:
            if row.get(field, "") != audit.get(field, ""):
                add_issue(
                    issues,
                    "error",
                    "fda_boxed_warning_review",
                    row=generic,
                    field=field,
                    message="CSV FDA boxed-warning field does not match audit extraction",
                    expected=audit.get(field, ""),
                    observed=row.get(field, ""),
                    source=audit.get("dailymed_url", ""),
                )
        status = audit.get("status", "")
        warning = row.get("fda_black_box_warning", "")
        source = row.get("fda_black_box_warning_source", "")
        if status == "boxed_warning_found":
            if not audit.get("dailymed_setid") or "dailymed.nlm.nih.gov" not in source:
                add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="fda_black_box_warning_source", message="Boxed warning lacks DailyMed setid/source URL", observed=source)
            if "WARNING" not in warning[:300].upper() and "WARNINGS" not in warning[:300].upper():
                add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="fda_black_box_warning", message="Boxed-warning text does not begin with FDA warning text", observed=warning[:300])
        elif status == "no_boxed_warning_in_selected_label":
            if warning != "No FDA boxed warning identified in selected current DailyMed label.":
                add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="fda_black_box_warning", message="No-boxed-warning row has unexpected text", observed=warning)
        elif status == "no_current_fda_label":
            if warning != "No current FDA/DailyMed label identified.":
                add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="fda_black_box_warning", message="No-current-label row has unexpected text", observed=warning)
        else:
            add_issue(issues, "error", "fda_boxed_warning_review", row=generic, field="status", message="Unexpected FDA boxed-warning audit status", observed=status)
        add_issue(
            issues,
            "info",
            "fda_boxed_warning_review",
            row=generic,
            field="fda_black_box_warning",
            message="FDA boxed-warning field matches generated DailyMed audit extraction",
            source=audit.get("dailymed_url", ""),
        )


def validate_html(rows, issues):
    html_text = HTML_PATH.read_text()
    app_text = APP_PATH.read_text() if APP_PATH.exists() else ""
    combined = html_text + "\n" + app_text

    if "app.js" not in html_text:
        add_issue(issues, "error", "html_display", field="app.js", message="HTML does not load the CSV-derived app script")
    if "ASM-list.csv" not in combined:
        add_issue(issues, "error", "html_display", field="fetch", message="App does not fetch ASM-list.csv")
    if "refreshDate" not in combined or "data_most_recently_refreshed" not in combined:
        add_issue(issues, "error", "html_display", field="data_most_recently_refreshed", message="App does not display the CSV refresh date")
    if "seizure_freedom_rct_rates" in combined:
        add_issue(issues, "error", "html_display", field="seizure_freedom_rct_rates", message="App still references obsolete active-rate seizure-freedom column")

    required_derivations = {
        "CSV-defined filter menus": ["FILTER_PREFIX", "startsWith(FILTER_PREFIX)", "state.filterColumns"],
        "CSV-derived display columns": ["state.displayColumns", "state.headers", "isInternalColumn"],
        "CSV-derived graph columns": ["GRAPH_PREFIX", "startsWith(GRAPH_PREFIX)", "state.graphColumns"],
        "CSV-derived ASM selector": ["populateAsmChecks", "state.rows.map"],
    }
    for label, snippets in required_derivations.items():
        if not all(snippet in combined for snippet in snippets):
            add_issue(issues, "error", "html_display", message=f"App does not clearly implement {label}")

    forbidden_static_logic = [
        "const columns = [",
        "mechanismCategories",
        "availabilityCategories",
        "formulationCategories",
        "enzymeCategories",
        "qtCategories",
        "symptomCategories",
        "epilepsyTypeCategories",
    ]
    for snippet in forbidden_static_logic:
        if snippet in combined:
            add_issue(issues, "error", "html_display", message="App still contains hardcoded display/filter logic", observed=snippet)


def source_urls_from_rows(rows):
    urls = set()
    source_fields = [
        "evidence_sources",
        "mechanism_source",
        "fda_black_box_warning_source",
    ]
    for row in rows:
        for field in source_fields:
            urls.update(re.findall(r"https?://[^\s;,]+", row.get(field, "")))
    return sorted(urls)


def review_sources_online(rows, issues, strict):
    for url in source_urls_from_rows(rows):
        try:
            fetched = fetch_url(url)
        except (urllib.error.URLError, TimeoutError, OSError) as exc:
            add_issue(issues, "error" if strict else "warning", "online_source_review", message="Could not fetch source URL listed in CSV", observed=str(exc), source=url)
            continue
        add_issue(issues, "info", "online_source_review", message="Fetched source URL listed in CSV", observed=f"HTTP {fetched['status']} {fetched['content_type']}", source=url)
    return {}


def write_reports(issues):
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    csv_path = REPORT_DIR / "confirm-data-report.csv"
    json_path = REPORT_DIR / "confirm-data-report.json"
    summary_path = REPORT_DIR / "confirm-data-summary.txt"
    fieldnames = ["severity", "check", "row", "field", "message", "expected", "observed", "source"]
    with csv_path.open("w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(issues)
    json_path.write_text(json.dumps(issues, indent=2))
    counts = Counter(issue["severity"] for issue in issues)
    summary = textwrap.dedent(
        f"""\
        confirm-data summary
        errors: {counts.get('error', 0)}
        warnings: {counts.get('warning', 0)}
        info: {counts.get('info', 0)}

        Detailed reports:
        - {csv_path.relative_to(ROOT)}
        - {json_path.relative_to(ROOT)}
        """
    )
    summary_path.write_text(summary)
    return csv_path, json_path, summary_path, counts


def main():
    parser = argparse.ArgumentParser(description="Validate ASM-list.csv source coverage, RCT provenance, and HTML display wiring.")
    parser.add_argument("--online", action="store_true", help="Fetch source URLs listed directly in the CSV and review accessibility.")
    parser.add_argument("--strict-online", action="store_true", help="Treat online source fetch failures as errors instead of warnings.")
    args = parser.parse_args()

    issues = []
    header, rows = read_csv_with_header(CSV_PATH)
    validate_schema(header, rows, issues)

    source_text_by_name = {}
    if args.online:
        source_text_by_name = review_sources_online(rows, issues, strict=args.strict_online)

    validate_sources(rows, issues, source_text_by_name)
    validate_rcts(rows, issues)
    validate_efficacy_outcome_audit(rows, issues)
    validate_seizure_freedom(rows, issues)
    validate_outcome_fields(rows, issues)
    validate_non_rct_fact_format(rows, issues)
    validate_mechanism_fields(rows, issues)
    validate_fda_boxed_warnings(rows, issues)
    validate_html(rows, issues)

    csv_path, json_path, summary_path, counts = write_reports(issues)
    print(summary_path.read_text().strip())
    if counts.get("error", 0):
        print("\nFirst errors:")
        for issue in [item for item in issues if item["severity"] == "error"][:20]:
            location = " / ".join(part for part in [issue["row"], issue["field"]] if part)
            print(f"- {issue['check']}: {location}: {issue['message']} {issue['observed']}".rstrip())
        raise SystemExit(1)
    print("\nNo blocking data-confirmation errors found.")


if __name__ == "__main__":
    main()
